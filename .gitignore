# Root Level Ignore
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS Files
.DS_Store
Thumbs.db
ehthumbs.db
eslint.config.js

# Note: We keep baddalni-react.code-workspace because it helps configure the editor

# =========================
# Frontend (React / Vite)
# =========================
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/.env
frontend/.env.*
frontend/.env.local
frontend/.env.*.local
frontend/coverage/

# =========================
# Backend (Laravel / PHP)
# =========================
backend/vendor/
backend/node_modules/
backend/public/build/
backend/public/hot
backend/public/storage
backend/storage/*.key
backend/.env
backend/.env.backup
backend/.phpunit.cache
backend/phpunit.result.cache
backend/Homestead.json
backend/Homestead.yaml
backend/auth.json
backend/.fleet/
backend/.idea/
backend/.vscode/
